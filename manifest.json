{
  "name": "EA PDF — Energy Assessment",
  "short_name": "EA PDF",
  "description": "Energy-assessment PDF measure & markup — per-page scales, tags, dimension lines, U-value build-ups",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "background_color": "#1e2124",
  "theme_color": "#26292d",
  "icons": [
    { "src": "icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "launch_handler": { "client_mode": "focus-existing" },
  "file_handlers": [
    {
      "action": "./",
      "accept": {
        "application/pdf": [".pdf"],
        "application/json": [".eapdf", ".brsproj", ".brsws"],
        "image/png": [".png"],
        "image/jpeg": [".jpg", ".jpeg"]
      }
    }
  ]
}
